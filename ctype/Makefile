
CFLAGS = -O2

SRC = gen_wcdata.c init_casemap.h init_ctype.h enc_casemap.h enc_ctype.h

ALL = iswalpha_table.h iswalpha_dict.h \
      iswpunct_table.h iswpunct_dict.h \
      wcwidth_table.h  wcwidth_dict.h  \
      towctrans_table.h towctrans_dict.h

OLD = deprecated/alpha.h deprecated/punct.h \
      deprecated/nonspacing.h deprecated/wide.h \
      deprecated/casemap.h

DATA = data/UnicodeData.txt data/DerivedCoreProperties.txt data/EastAsianWidth.txt

all: $(ALL)

clean:
	rm -f $(ALL)
	rm -f gen_wcdata test_wcdata test_wcdata_deprec
	rm -f $(OLD)
	rm -f deprecated/{arrayify,gen_casemap,gen_ctype,gen_nonspacing,gen_wide}

test: $(ALL) test_wcdata test_wcdata_deprec
	@echo
	@echo "Testing chartable-tools data against original musl functions:" 
	./test_wcdata_deprec -t a
	./test_wcdata_deprec -t p
	./test_wcdata_deprec -t w
	./test_wcdata_deprec -t u
	./test_wcdata_deprec -t l
	@echo
	@echo "Testing chartable-tools data against new musl functions:" 
	./test_wcdata -t a
	./test_wcdata -t p
	./test_wcdata -t w
	./test_wcdata -t u
	./test_wcdata -t l

gen_wcdata: $(SRC)
	$(CC) $(CFLAGS) $(CPPFLAGS) -o $@ gen_wcdata.c

test_wcdata: $(SRC) $(ALL) iswalpha.c iswpunct.c wcwidth.c towctrans.c
	$(CC) $(CFLAGS) $(CPPFLAGS) -o $@ gen_wcdata.c iswalpha.c iswpunct.c wcwidth.c towctrans.c

# Headers generated by gen_wcdata

iswalpha_table.h: $(DATA) gen_wcdata
	./gen_wcdata a > $@

iswalpha_dict.h: $(DATA) gen_wcdata
	./gen_wcdata A > $@

iswpunct_table.h: $(DATA) gen_wcdata
	./gen_wcdata p > $@

iswpunct_dict.h: $(DATA) gen_wcdata
	./gen_wcdata P > $@

wcwidth_table.h: $(DATA) gen_wcdata
	./gen_wcdata w > $@

wcwidth_dict.h: $(DATA) gen_wcdata
	./gen_wcdata W > $@

towctrans_table.h: $(DATA) gen_wcdata
	./gen_wcdata c > $@

towctrans_dict.h: $(DATA) gen_wcdata
	./gen_wcdata C > $@

# Below are the deprecated headers, which are kept only for regression testing

deprecated/alpha.h: data/UnicodeData.txt data/DerivedCoreProperties.txt deprecated/gen_ctype deprecated/arrayify
	deprecated/gen_ctype a | deprecated/arrayify > $@

deprecated/punct.h: data/UnicodeData.txt data/DerivedCoreProperties.txt deprecated/gen_ctype deprecated/arrayify
	deprecated/gen_ctype p | deprecated/arrayify > $@

deprecated/nonspacing.h: data/UnicodeData.txt deprecated/gen_nonspacing deprecated/arrayify
	deprecated/gen_nonspacing | deprecated/arrayify > $@

deprecated/wide.h: data/EastAsianWidth.txt deprecated/gen_wide deprecated/arrayify
	deprecated/gen_wide | deprecated/arrayify > $@

deprecated/casemap.h: data/UnicodeData.txt deprecated/gen_casemap
	deprecated/gen_casemap < $< > $@

test_wcdata_deprec: $(SRC) $(OLD) deprecated/iswalpha.c deprecated/iswpunct.c deprecated/wcwidth.c deprecated/towctrans.c
	$(CC) $(CFLAGS) $(CPPFLAGS) -o $@ gen_wcdata.c deprecated/{iswalpha.c,iswpunct.c,wcwidth.c,towctrans.c}

