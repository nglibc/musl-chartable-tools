
CFLAGS = -O2

ALL = iswalpha_table.h iswalpha_dict.h \
      iswpunct_table.h iswpunct_dict.h \
      wcwidth_table.h  wcwidth_dict.h  casemap.h

OLD = alpha.h punct.h nonspacing.h wide.h

all: $(ALL)

clean:
	rm -f $(ALL) $(OLD) gen_casemap gen_wcdata test_wcdata test_wcdata_v0 arrayify gen_ctype gen_nonspacing gen_wide

test: $(ALL) test_wcdata test_wcdata_v0
	@echo
	@echo "Testing chartable-tools data against original musl functions:" 
	./test_wcdata_v0 -t a
	./test_wcdata_v0 -t p
	./test_wcdata_v0 -t v
	@echo
	@echo "Testing chartable-tools data against new musl functions:" 
	./test_wcdata -t a
	./test_wcdata -t p
	./test_wcdata -t v

test_wcdata: gen_wcdata.c iswalpha.c iswpunct.c wcwidth.c $(ALL)
	$(CC) $(CFLAGS) $(CPPFLAGS) gen_wcdata.c iswalpha.c iswpunct.c wcwidth.c -o $@

test_wcdata_v0: gen_wcdata.c iswalpha_v0.c iswpunct_v0.c wcwidth_v0.c $(OLD)
	$(CC) $(CFLAGS) $(CPPFLAGS) gen_wcdata.c iswalpha_v0.c iswpunct_v0.c wcwidth_v0.c -o $@

# Headers generated by gen_wcdata and gen_casemap

iswalpha_table.h: data/UnicodeData.txt data/DerivedCoreProperties.txt gen_wcdata
	./gen_wcdata a > $@

iswalpha_dict.h: data/UnicodeData.txt data/DerivedCoreProperties.txt gen_wcdata
	./gen_wcdata A > $@

iswpunct_table.h: data/UnicodeData.txt data/DerivedCoreProperties.txt gen_wcdata
	./gen_wcdata p > $@

iswpunct_dict.h: data/UnicodeData.txt data/DerivedCoreProperties.txt gen_wcdata
	./gen_wcdata P > $@

wcwidth_table.h: data/UnicodeData.txt data/DerivedCoreProperties.txt gen_wcdata
	./gen_wcdata w > $@

wcwidth_dict.h: data/UnicodeData.txt data/DerivedCoreProperties.txt gen_wcdata
	./gen_wcdata W > $@

casemap.h: data/UnicodeData.txt gen_casemap
	./gen_casemap < $< > $@

# Below are the deprecated headers, which are kept only for regression testing

alpha.h: data/UnicodeData.txt data/DerivedCoreProperties.txt gen_ctype arrayify
	./gen_ctype a | ./arrayify > $@

punct.h: data/UnicodeData.txt data/DerivedCoreProperties.txt gen_ctype arrayify
	./gen_ctype p | ./arrayify > $@

nonspacing.h: data/UnicodeData.txt gen_nonspacing arrayify
	./gen_nonspacing | ./arrayify > $@

wide.h: data/EastAsianWidth.txt gen_wide arrayify
	./gen_wide | ./arrayify > $@


